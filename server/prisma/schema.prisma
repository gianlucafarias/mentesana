// This is your Prisma schema file
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RoleType {
  USER
  EDITOR
  ADMIN
}

enum EventType {
  PRESENCIAL
  VIRTUAL
  HIBRIDO
  OTRO
}

enum AchievementStatus {
  LOCKED
  IN_PROGRESS
  UNLOCKED
}

enum UserActivityEventType {
  TOOL_COMPLETED
  RESOURCE_VIEWED
  WEEKLY_SUMMARY_VIEWED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  birthDate     DateTime?  // Fecha de nacimiento
  locality      String?    // Localidad
  province      String?    // Provincia
  doesSport     Boolean?
  sportFrequency String?
  therapyHistory String?
  hasSiblings   Boolean?
  siblingsCount Int?
  livesWith     String?
  hobbies       String[]
  screenTimeHours Int?
  sleepHours    Int?
  extracurricularActivities String?
  researchConsent Boolean  @default(false)
  role          RoleType   @default(USER)
  isActive      Boolean    @default(true)  // Campo para activar/desactivar usuarios
  lastLogin     DateTime?  // Fecha y hora del último inicio de sesión
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  posts         Post[]
  events        Event[]
  dailyEntries  DailyEntry[]
  notifications Notification[]
  insights      UserInsight[]
  achievements  UserAchievement[]
  activityEvents UserActivityEvent[]
  weeklySummaries WeeklySummary[]
}

model Post {
  id        String    @id @default(uuid())
  title     String
  content   String
  image     String?   // URL o ruta 
  category  String?   // Categoría del post
  published Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  author    User      @relation(fields: [authorId], references: [id])
  authorId  String
}

model Event {
  id          String    @id @default(uuid())
  title       String
  description String
  date        DateTime
  location    String?
  image       String?   // URL o ruta
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      User      @relation(fields: [authorId], references: [id])
  authorId    String
  eventType   EventType
}

model DailyEntry {
  id        String    @id @default(uuid())
  mood      Int       
  notes     String?
  aiMessage String?   // Mensaje motivacional generado por IA
  aiMessageData Json? // Payload estructurado para UI
  riskLevel String?   // low|medium|high|critical
  safetyFlags Json?   // flags de seguridad detectados por IA
  aiModel   String?
  aiPromptVersion String?
  entryDate String
  date      DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id])
  userId    String

  @@unique([userId, entryDate])
  @@index([userId, date])
}

model WeeklySummary {
  id              String   @id @default(uuid())
  userId          String
  weekStart       DateTime
  weekEnd         DateTime
  summary         String
  advice          String
  riskLevel       String?
  safetyFlags     Json?
  aiModel         String?
  aiPromptVersion String?
  statsData       Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId, weekEnd])
}

model Notification {
  id          String    @id @default(uuid())
  type        String    // Tipo de notificación (ej: "event", "post", "system")
  title       String
  message     String
  read        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  link        String?   // URL opcional relacionada con la notificación
}

model UserInsight {
  id                String   @id @default(uuid())
  userId            String
  type              String   // 'pattern', 'recommendation', 'trend', 'correlation'
  title             String
  description       String
  confidence        Float    // 0.0 a 1.0
  actionable        Boolean  @default(false)
  actionText        String?  // Texto de la acción recomendada
  actionUrl         String?  // URL de la acción
  insightsData      Json?    // Datos adicionales estructurados
  lastGenerated     DateTime @default(now())
  nextGenerationDate DateTime? // Cuándo se debe regenerar (opcional)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  user              User     @relation(fields: [userId], references: [id])
  
  @@index([userId, isActive])
  @@index([nextGenerationDate])
}

model AchievementDefinition {
  id          String            @id @default(uuid())
  key         String            @unique
  title       String
  description String
  category    String
  target      Int
  icon        String
  tone        String
  isActive    Boolean           @default(true)
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  users       UserAchievement[]
}

model UserAchievement {
  id             String             @id @default(uuid())
  userId         String
  achievementId  String
  current        Int                @default(0)
  target         Int
  status         AchievementStatus  @default(LOCKED)
  unlockedAt     DateTime?
  lastProgressAt DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement    AchievementDefinition @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId, status])
  @@index([userId, unlockedAt])
}

model UserActivityEvent {
  id         String                @id @default(uuid())
  userId     String
  type       UserActivityEventType
  date       DateTime              @default(now())
  eventKey   String
  metadata   Json?
  createdAt  DateTime              @default(now())
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, eventKey])
  @@index([userId, type, date])
}
